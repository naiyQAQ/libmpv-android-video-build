 libavcodec/Makefile     |   1 +
 libavcodec/allcodecs.c  |   3 +
 libavcodec/libbytevc2.c | 344 ++++++++++++++++++++++++++++++++++++++++
 4 files changed, 352 insertions(+)
 create mode 100644 libavcodec/libbytevc2.c

